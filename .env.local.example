# Telegram Bot credentials
# Setup steps:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot — follow prompts to name your bot
#   3. BotFather gives you a token like: 123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   4. Start a chat with your new bot (search its username and press Start)
#   5. Visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates to find your chat_id
#      Look for: "chat":{"id": 123456789, ...}

TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# Binance API — for automated spot trading
# Production keys: https://www.binance.com/en/my/settings/api-management
#   - Enable "Spot & Margin Trading" permission
#   - Restrict to your server IP for security
# Testnet keys (fake money): https://testnet.binance.vision (login with GitHub)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
# Set to "true" to use testnet — ALWAYS test here before using real funds
BINANCE_TESTNET=true

# VPS Proxy — bypasses Binance geo-restrictions from Vercel's servers
# VPS_PROXY_URL: your VPS public IP/domain + port, e.g. http://1.2.3.4:4000
# PROXY_SECRET: a long random string shared between Vercel and the proxy
#   Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VPS_PROXY_URL=http://YOUR_VPS_IP:4000
PROXY_SECRET=your_random_secret_here
