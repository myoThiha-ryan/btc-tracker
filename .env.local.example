# Telegram Bot credentials
# Setup steps:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot — follow prompts to name your bot
#   3. BotFather gives you a token like: 123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   4. Start a chat with your new bot (search its username and press Start)
#   5. Visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates to find your chat_id
#      Look for: "chat":{"id": 123456789, ...}

TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789
