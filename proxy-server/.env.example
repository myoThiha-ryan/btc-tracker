# A long random secret shared between Vercel and this proxy
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROXY_SECRET=your_random_secret_here

# Set to "true" to forward to testnet.binance.vision, otherwise api.binance.com
BINANCE_TESTNET=true

# Port the proxy listens on (default 4000)
PORT=4000
